# ─── Core ─────────────────────────────────────────────────────────────────
# APP_ENV: development | production
APP_ENV=development
HTTP_ADDR=:8080
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# Optional. When set, every /v1/* request must send
# "Authorization: Bearer $API_TOKEN". Leave blank to disable auth.
API_TOKEN=

# ─── Trading mode ─────────────────────────────────────────────────────────
# mock   – trades entirely in-memory; no broker required
# paper  – routes orders through Alpaca's paper-trading endpoint
# live   – routes orders through Alpaca live (requires approved account)
TRADER_MODE=mock

# ─── Engine loops ─────────────────────────────────────────────────────────
ENGINE_ENABLED=true
INGEST_INTERVAL=15m
DECIDE_INTERVAL=5m
# Wave 5: how often the engine writes a full portfolio valuation
# (cash, cost basis, mark-to-market, realised, unrealised, equity)
# to the `equity_snapshots` table. Drives the equity curve chart on
# the Overview / Analytics pages. 5m ≈ 288 rows/day per portfolio.
EQUITY_SNAPSHOT_INTERVAL=5m
# Max age the equity_snapshots table will grow to before the hourly
# retention sweeper starts deleting. Default 90 days (2160h). Zero
# disables retention (not recommended in prod).
EQUITY_SNAPSHOT_RETENTION=2160h

# ─── Wallet / Risk limits ─────────────────────────────────────────────────
# $10,000 seed wallet for mock mode
INITIAL_WALLET_CENTS=1000000
MAX_ORDER_USD=1000
MAX_POSITION_USD=2500
MAX_DAILY_LOSS_USD=500
MAX_DAILY_ORDERS=20
# Max fraction of equity into a single symbol (0..1).
MAX_SYMBOL_EXPOSURE=0.2
# Comma-separated tickers never to trade.
SYMBOL_BLACKLIST=

# Exit policy: mechanical take-profit / stop-loss as fractions of
# average cost. Evaluated on every decide tick for held positions
# before any LLM/signal logic — this is the safety net that ensures
# winners are booked and losers are cut even during quiet news cycles.
# Set to 0 to disable either leg.
TAKE_PROFIT_PCT=0.25
STOP_LOSS_PCT=0.10

# Bound the per-tick evaluation cost: only the top-N merged signals
# (by absolute score) are considered as new opportunities. Held
# positions are ALWAYS evaluated regardless of this cap. Sized to
# comfortably fit per-kind quotas + discovery slots + a normal book.
WATCHLIST_CAP=30
# When true, decisions wait for a manual /execute call.
REQUIRE_APPROVAL=false

# ─── Diversification & discovery (Wave 2.5) ───────────────────────────────
# PER_KIND_CAP bounds how many candidates each signal kind
# (politician/news/momentum/...) may contribute to the per-tick
# evaluation pool. Prevents a single strategy's leaderboard from
# swallowing every slot. Set 0 to disable per-kind quotas.
PER_KIND_CAP=5
# DISCOVERY_SLOTS reserves evaluation slots for unheld symbols so
# fresh names actually get considered even when held positions
# crowd the top of the merged leaderboard. 0 disables.
DISCOVERY_SLOTS=5
# Drop candidates below this confidence from the per-kind and
# discovery passes. Held positions always evaluate regardless of
# confidence (exits must always fire).
CANDIDATE_CONFIDENCE_FLOOR=0.35
# Hard cap on distinct open symbols. Buys that would open a NEW
# position are rejected once this count is hit; re-buys on existing
# positions and sells are unaffected. 0 disables the cap entirely.
MAX_CONCURRENT_POSITIONS=15
# Age-decay half-life for individual politician disclosures inside
# the strategy's aggregation window. A 7-day half-life means a
# trade 7 days old counts for half the weight of a trade today.
# Keeps the politician leaderboard churning instead of pinning the
# same 6 names for the full 21-day lookback. 0 disables decay.
POLITICIAN_HALFLIFE=168h

# ─── Technical momentum (Wave 2.1) ────────────────────────────────────────
# The momentum strategy pulls daily OHLCV bars (Stooq by default) and
# emits signals from moving-average structure, RSI, and 52-week range.
# Disable it with MOMENTUM_ENABLED=false if the bar provider becomes
# unreliable in your environment.
MOMENTUM_ENABLED=true
# Symbols always evaluated for momentum even without a politician or
# news signal. Comma-separated. Held positions are added automatically.
MOMENTUM_WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,AMD,NFLX,SPY,QQQ
# Filter out low-conviction classifications. 0 disables the filter.
MOMENTUM_MIN_CONFIDENCE=0.4

# ─── Robust operations (Wave 3) ───────────────────────────────────────────
# STRATEGIES gates which strategies the engine registers at startup.
# Comma-separated subset of {politician,news,momentum}. Empty = all
# (default). Useful when a data source is flapping and you want to
# temporarily isolate a strategy without rebuilding.
STRATEGIES=
# ORDER_STALE_TIMEOUT: any order still in `submitted` state longer than
# this is proactively cancelled at the broker during Reconcile. Prevents
# stuck partials from holding a cash reservation forever. Set to 0 to
# disable the sweeper.
ORDER_STALE_TIMEOUT=15m
# AUTO_DISABLE_BROKER_REJECTS: trip the broker-outage circuit breaker
# after this many broker-source rejections inside AUTO_DISABLE_BROKER_WINDOW.
# The engine self-disables (Enabled=false) so an ops human can investigate.
# Set to 0 to disable the breaker.
AUTO_DISABLE_BROKER_REJECTS=10
AUTO_DISABLE_BROKER_WINDOW=10m
# AUTO_DISABLE_DAILY_LOSS_USD: trip the daily-loss circuit breaker when
# realised P&L since UTC midnight drops below −N dollars. Set to 0 to
# disable the breaker (not recommended for live trading).
AUTO_DISABLE_DAILY_LOSS_USD=0

# ─── Broker ───────────────────────────────────────────────────────────────
# BROKER_PROVIDER: mock | alpaca
BROKER_PROVIDER=mock
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ─── LLM (OpenAI-compatible endpoint) ─────────────────────────────────────
# Works with any OpenAI-compatible /v1/chat/completions endpoint:
#   - Self-hosted model-router (default below)
#   - OpenRouter:    https://openrouter.ai/api/v1  (set LLM_API_KEY)
#   - OpenAI direct: https://api.openai.com/v1     (set LLM_API_KEY)
# LLM_API_KEY is optional – leave blank when the router has auth disabled.
# The legacy OPENROUTER_API_KEY / OPENROUTER_BASE_URL variables are still
# honored as fallbacks for backwards compatibility.
LLM_BASE_URL=http://192.168.1.249:8080/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_FALLBACK_MODELS=anthropic/claude-3.5-haiku,google/gemini-2.0-flash,ollama/llama3.1

# ─── LLM cost tracking ────────────────────────────────────────────────────
# Every chat completion (including each fallback attempt) is persisted to
# the `llm_calls` table with tokens, latency, outcome, trace_id, full
# request/response, and computed USD cost. Query it via:
#   GET /v1/llm/calls              – paginated list (filter by operation/model/outcome/since)
#   GET /v1/llm/usage?group_by=day – totals + buckets (day|hour|model|operation|outcome)
#
# LLM_PRICING_JSON overrides the built-in price table. Values are USD
# per 1M tokens. Unknown/local models cost $0 by default. Example:
# LLM_PRICING_JSON={"openai/gpt-4o-mini": {"input_per_1m":"0.15","output_per_1m":"0.60"}}
LLM_PRICING_JSON=

# Prism gateway extensions (Wave 4 layered grounding). Both are off
# by default because an enabled-but-misconfigured extension is the
# single most common cause of empty `message.content` responses.
# PRISM_WEB_SEARCH_ENABLED is only honored when PRISM_SEARXNG_URL is
# set; if the URL is blank the extension is force-disabled at load
# time regardless of the toggle. The client automatically retries
# without extensions when a response comes back empty, so enabling
# these is safe — you'll see degraded (non-grounded) answers but
# never lose the tick entirely.
PRISM_WEB_SEARCH_ENABLED=false
PRISM_SEARXNG_URL=
PRISM_MAX_RESULTS=3
PRISM_DATETIME_ENABLED=false
PRISM_DEFAULT_TIMEZONE=America/Chicago

# ─── Data providers ───────────────────────────────────────────────────────
QUIVER_TOKEN=
FINNHUB_KEY=
NEWSAPI_KEY=
ALPHAVANTAGE_KEY=
CAPITOLTRADES_URL=https://bff.capitoltrades.com/trades

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=file:data/trader.db?_time_format=sqlite&_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)&_pragma=foreign_keys(on)

# ─── Observability (OpenTelemetry) ────────────────────────────────────────
# When OTEL_EXPORTER_OTLP_ENDPOINT is empty the OTLP exporters are NOT
# initialised; the process still exposes /metrics (Prometheus pull)
# and logs trace_id/span_id on every HTTP request, so local dev stays
# noise-free.
#
# Point this at your collector (in-cluster typical: http://otel-collector.observability.svc.cluster.local:4317).
OTEL_EXPORTER_OTLP_ENDPOINT=
# TLS control. "true" to use plaintext gRPC (in-cluster), "false" otherwise.
OTEL_EXPORTER_OTLP_INSECURE=true
# Overrides the default service.name resource attribute.
OTEL_SERVICE_NAME=trader
# Free-form resource attributes, comma-separated k=v pairs. See
# https://opentelemetry.io/docs/specs/otel/resource/sdk/#environment-variables
OTEL_RESOURCE_ATTRIBUTES=
# Sampling. See https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/
# Leave empty to keep the default (parentbased_always_on).
OTEL_TRACES_SAMPLER=
OTEL_TRACES_SAMPLER_ARG=

# Optional. When set, serves pprof + expvar on this address (e.g. :6060).
# Disabled by default; never expose this port publicly.
PPROF_ADDR=
