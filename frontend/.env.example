# Frontend env. Copy to .env.local to override in development.

# URL the axios client calls. In dev the Vite proxy forwards /api -> API.
VITE_API_URL=/api

# Where the Vite dev server proxies /api to.
VITE_API_PROXY_TARGET=http://localhost:8080

# Bearer token if the backend sets API_TOKEN. Leave empty for unauthenticated dev.
VITE_API_TOKEN=

# Default portfolio selected in the sidebar. Leave empty to auto-pick
# the first portfolio returned by the API.
VITE_DEFAULT_PORTFOLIO_ID=

VITE_APP_NAME=Trader
